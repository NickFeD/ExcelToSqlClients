<Window x:Class="ExcelToSqlClients.Dynamic.Desktop.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Viewer/Editor" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Refresh tables" Command="{Binding RefreshTablesCommand}" Margin="0,0,12,0"/>

                <TextBlock VerticalAlignment="Center" Text="Table:" Margin="0,0,8,0"/>
                <ComboBox Width="320"
                          ItemsSource="{Binding Tables}"
                          SelectedItem="{Binding SelectedTable}"
                          DisplayMemberPath="FullName"
                          Margin="0,0,12,0"/>

                <Button Content="Save changes"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanEdit}"
                        Margin="0,0,8,0"/>

                <TextBlock VerticalAlignment="Center"
                           Foreground="Gray"
                           Text="{Binding CanEdit, StringFormat=Editable: {0}}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       Foreground="Gray"/>
        </DockPanel>

        <DataGrid x:Name="Grid"
                  Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  IsReadOnly="{Binding CanEdit, Converter={StaticResource BoolInvertConverter}}"
                  Loaded="Grid_Loaded"
                  AddingNewItem="Grid_AddingNewItem"
                  CellEditEnding="Grid_CellEditEnding"

                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.IsDeferredScrollingEnabled="True"/>
    </Grid>
</Window>