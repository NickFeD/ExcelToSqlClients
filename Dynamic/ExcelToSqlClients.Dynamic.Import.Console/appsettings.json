{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=ExcelToSqlClientsDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "DynamicSchema": {
    "Schema": "dbo",
    "Table": "Clients",
    "Columns": [
      {
        // Имя колонки в SQL-таблице
        "Name": "CardCode",

        // SQL-тип колонки (как в DDL): int, bigint, nvarchar(200), decimal(18,2), datetime2 и т.п
        "SqlType": "nvarchar(50)",
        // Разрешено ли NULL
        "Nullable": false,
        // Является ли колонка частью первичного ключа
        "IsPrimaryKey": true,
        // Должны ли значения быть уникальными (уникальный индекс/ограничение)
        "IsUnique": true
      },
      { "Name": "LastName", "SqlType": "nvarchar(100)", "Nullable": true },
      { "Name": "FirstName", "SqlType": "nvarchar(100)", "Nullable": true },
      { "Name": "SurName", "SqlType": "nvarchar(100)", "Nullable": true },
      { "Name": "PhoneMobile", "SqlType": "nvarchar(20)", "Nullable": true },
      { "Name": "Email", "SqlType": "nvarchar(254)", "Nullable": true },
      { "Name": "GenderId", "SqlType": "nvarchar(20)", "Nullable": true },
      { "Name": "Birthday", "SqlType": "date", "Nullable": true },
      { "Name": "City", "SqlType": "nvarchar(200)", "Nullable": true },
      { "Name": "Pincode", "SqlType": "nvarchar(20)", "Nullable": true },
      { "Name": "Bonus", "SqlType": "int", "Nullable": true },
      { "Name": "Turnover", "SqlType": "bigint", "Nullable": true }
    ]
  },
  "Import": {
    "BatchSize": 1000,
    "IgnoreErrors": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
