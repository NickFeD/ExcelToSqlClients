<Window x:Class="ExcelToSqlClients.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clients Editor" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock VerticalAlignment="Center" Text="Search:" Margin="0,0,8,0"/>
                <TextBox Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,12,0"/>
                <Button Content="Load"
                        Command="{Binding LoadCommand}"
                        Margin="0,0,8,0" Width="90"/>
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Margin="0,0,8,0" Width="90"/>
                <Button Content="Reload"
                        Command="{Binding ReloadCommand}"
                        Width="90"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Text="{Binding StatusText}"
                       Foreground="Gray"/>
        </DockPanel>

        <!-- Data grid -->
        <DataGrid x:Name="Grid"
                  Grid.Row="2"
                  ItemsSource="{Binding Clients}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  RowHeight="26"
                  Loaded="Grid_Loaded"

                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.IsDeferredScrollingEnabled="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="CardCode" Binding="{Binding CardCode}" IsReadOnly="True" Width="120"/>
                <DataGridTextColumn Header="LastName" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="FirstName" Binding="{Binding FirstName}" Width="120"/>
                <DataGridTextColumn Header="SurName" Binding="{Binding SurName}" Width="120"/>
                <DataGridTextColumn Header="PhoneMobile" Binding="{Binding PhoneMobile}" Width="140"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="GenderId" Binding="{Binding GenderId}" Width="70"/>
                <DataGridTextColumn Header="Birthday" Binding="{Binding Birthday}" Width="110"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="140"/>
                <DataGridTextColumn Header="Pincode" Binding="{Binding Pincode}" Width="90"/>
                <DataGridTextColumn Header="Bonus" Binding="{Binding Bonus}" Width="80"/>
                <DataGridTextColumn Header="Turnover" Binding="{Binding Turnover}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,10,0,0" Foreground="Gray"
                   Text="Scroll down to auto-load more rows. CardCode is read-only." />
    </Grid>
</Window>